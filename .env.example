# Postgres (Vultr Managed Databases)
DATABASE_URL=postgres://revagent:revagent@localhost:5432/revagent

# Gemini (Google AI Studio / Gemini API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0-pro

# Speechmatics (Real-Time WebSocket)
SPEECHMATICS_API_KEY=
SPEECHMATICS_RT_URL=wss://eu.rt.speechmatics.com/v2

# Featherless (OpenAI-compatible endpoint)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL_OBJECTIONS=
FEATHERLESS_MODEL_JTBD=
FEATHERLESS_MODEL_CLASSIFIER=
FEATHERLESS_MODEL_VOICE=

# Vultr Object Storage (S3-compatible)
VULTR_S3_ENDPOINT=
VULTR_S3_REGION=ewr1
VULTR_S3_BUCKET=revagent
VULTR_S3_ACCESS_KEY=
VULTR_S3_SECRET_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=digests@revagent.ai

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
APP_SHARED_SECRET=replace-me-with-openssl-rand-hex-32
NODE_ENV=development
PORT=4000
